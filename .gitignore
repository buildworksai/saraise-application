# ====================
dump.rdb
*.rdb

# ====================
# Docker
# ====================
.dockerignore
docker-compose.override.yml

# ====================
# CI/CD
# ====================
.github/workflows/*.local.yml

# ====================
# Reports (Keep structure, ignore temp)
# ====================
# Reports folder is tracked - all investigation reports belong here
# Only ignore temporary files
reports/*.tmp
reports/*.temp
reports/*.bak

# ====================
# Terraform / Infrastructure
# ====================
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
terraform.tfvars

# ====================
# Keep important files
# ====================
!.gitkeep
!.gitignore
!.pre-commit-config.yaml
!.github/
