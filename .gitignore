.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.cover
*.py,cover
.hypothesis/
nosetests.xml
coverage.xml
*.mo
*.pot

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Django Migrations
# Do NOT ignore migrations - they are source controlled
# backend/src/modules/*/migrations/*.py

