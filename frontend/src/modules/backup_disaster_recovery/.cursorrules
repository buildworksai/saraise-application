# Backup Disaster Recovery Module - Cursor Rules
# These rules are automatically applied when editing files in this directory

# =============================================================================
# MODULE OVERVIEW
# =============================================================================
#
# This module manages governed recovery points, restores, versioned runbooks,
# exercises, step evidence, readiness, and RPO/RTO reporting.
# Status: Production domain implementation (API v2)

# =============================================================================
# CRITICAL: Read contracts.ts FIRST
# =============================================================================
#
# Before modifying any file in this module, you MUST read:
#   frontend/src/modules/backup_disaster_recovery/contracts.ts
#
# This file contains:
# - All TypeScript types for this module
# - All API endpoint URLs
# - Governed v2 envelopes, pagination, and error contracts
# - Provider-neutral discriminated parameter and evidence types

# =============================================================================
# TYPE IMPORTS
# =============================================================================
#
# ✅ CORRECT: Import types from contracts.ts
#   import { RecoveryPoint, ENDPOINTS } from './contracts';
#
# ❌ FORBIDDEN: Import directly from @/types/api in pages/components
#   import type { components } from '@/types/api';
#
# Page-local view-state interfaces are permitted; API DTOs are not.

# =============================================================================
# ENDPOINT USAGE
# =============================================================================
#
# ✅ CORRECT: Use ENDPOINTS constant
#   apiClient.get<ApiV2Page<RecoveryPoint>>(ENDPOINTS.RECOVERY_POINTS.LIST);
#
# ❌ FORBIDDEN: Hardcode URL strings
#   apiClient.get('/api/v2/backup-disaster-recovery/recovery-points/');

# =============================================================================
# VALIDATION CHECKPOINTS
# =============================================================================
#
# After editing any TypeScript file in this module:
# 1. Run: npx tsc --noEmit src/modules/backup_disaster_recovery/{file}.tsx
# 2. Run: npx eslint src/modules/backup_disaster_recovery/{file}.tsx --max-warnings 0
# 3. Fix ALL errors before proceeding
