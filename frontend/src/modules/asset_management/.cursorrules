# Asset Management Module Rules
#
# Read contracts.ts before modifying this module.
# Import public domain types from contracts.ts, never from generated API types.
# Use ENDPOINTS for every API path; hardcoded API URLs are forbidden.
# Keep tenant identity and calculated balances server-owned.
# Depreciation history is append-only: new entries only use the asset command.
# All pages must remain registered in routes.ts and reachable from its sidebar parent.
#
# Verification:
#   npm run typecheck
#   npx eslint src/modules/asset_management --ext .ts,.tsx --max-warnings 0
#   npm test -- --run src/modules/asset_management
