# Workflow automation frontend rules
# Read contracts.ts before modifying module code.
# Import all domain DTOs from contracts.ts and use ENDPOINTS/ROUTES.
# Never accept raw assignee UUIDs, arbitrary URLs, scripts, or untyped JSON.
# Preserve governed envelopes, correlation IDs, optimistic concurrency, and extension availability.
# Validate with typecheck, zero-warning ESLint, Vitest, and a production build.
