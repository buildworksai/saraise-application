# Security & Access Control Module - Cursor Rules
# These rules are automatically applied when editing files in this directory

# =============================================================================
# CRITICAL: SECURITY-SENSITIVE MODULE
# =============================================================================
#
# This module handles roles, permissions, and access control.
# Changes here can affect security across the entire platform.
# Exercise extra caution when modifying.

# =============================================================================
# CRITICAL: Read contracts.ts FIRST
# =============================================================================
#
# Before modifying any file in this module, you MUST read:
#   frontend/src/modules/security_access_control/contracts.ts
#
# This file contains:
# - All TypeScript types for this module
# - All API endpoint URLs
# - Type guards for runtime checking
# - Usage examples

# =============================================================================
# TYPE IMPORTS
# =============================================================================
#
# ✅ CORRECT: Import types from contracts.ts
#   import { Role, Permission, PermissionSet, ENDPOINTS } from './contracts';
#   import type { RoleCreateRequest, RoleType } from './contracts';
#
# ❌ FORBIDDEN: Import directly from @/types/api in pages/components
#   import type { components } from '@/types/api';
#
# ❌ FORBIDDEN: Define ad-hoc types in page files
#   interface Role { id: string; name: string; } // DON'T DO THIS

# =============================================================================
# ENDPOINT USAGE
# =============================================================================
#
# ✅ CORRECT: Use ENDPOINTS constant
#   apiClient.get<Role[]>(ENDPOINTS.ROLES.LIST);
#   apiClient.get<Permission[]>(ENDPOINTS.PERMISSIONS.LIST);
#   apiClient.get<SecurityAuditLog[]>(ENDPOINTS.AUDIT_LOGS.LIST);
#
# ❌ FORBIDDEN: Hardcode URL strings
#   apiClient.get('/api/v1/security/roles/');

# =============================================================================
# API CLIENT USAGE
# =============================================================================
#
# ✅ CORRECT: Always specify generic type parameter
#   apiClient.get<Role[]>(ENDPOINTS.ROLES.LIST);
#   apiClient.post<Role>(ENDPOINTS.ROLES.CREATE, data);
#
# ❌ FORBIDDEN: Omit generic type or use any
#   apiClient.get(ENDPOINTS.ROLES.LIST);
#   apiClient.post<any>(ENDPOINTS.ROLES.CREATE, data);

# =============================================================================
# SECURITY CONSIDERATIONS
# =============================================================================
#
# When working with this module:
# 1. Never expose sensitive data in console logs
# 2. Always validate role types using type guards
# 3. Handle permission errors gracefully
# 4. Never cache sensitive permission data client-side
#
# Use type guards for runtime validation:
#   import { isRoleType, isProfileType } from './contracts';
#   if (isRoleType(value)) { /* safe to use */ }

# =============================================================================
# VALIDATION CHECKPOINTS
# =============================================================================
#
# After editing any TypeScript file in this module:
# 1. Run: npx tsc --noEmit src/modules/security_access_control/{file}.tsx
# 2. Run: npx eslint src/modules/security_access_control/{file}.tsx --max-warnings 0
# 3. Fix ALL errors before proceeding

# =============================================================================
# SERVICE FILE RULES
# =============================================================================
#
# The service file (services/security-service.ts) should:
# 1. Import types from ../contracts, not define its own
# 2. Use ENDPOINTS from ../contracts for all API calls
# 3. Handle 403 errors appropriately (insufficient permissions)
#
# Example:
#   import { Role, RoleCreateRequest, Permission, ENDPOINTS } from '../contracts';
#   
#   export const securityService = {
#     roles: {
#       list: () => apiClient.get<Role[]>(ENDPOINTS.ROLES.LIST),
#       create: (data: RoleCreateRequest) => apiClient.post<Role>(ENDPOINTS.ROLES.CREATE, data),
#     },
#     permissions: {
#       list: () => apiClient.get<Permission[]>(ENDPOINTS.PERMISSIONS.LIST),
#     },
#   };

