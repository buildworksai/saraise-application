# Bank Reconciliation Module Rules

# This is a production v2 module. `contracts.ts` is the frontend authority for
# all DTOs, literal enums, API endpoints, application routes, and query keys.

# Required boundaries
# - Never expose raw bank account identifiers in read DTOs or UI.
# - Never add a v1 response fallback or hardcoded API URL.
# - Keep decimal amounts as strings and use exact fixed-point arithmetic.
# - Treat HTTP 202 import responses as accepted work, not completion.
# - Imported source values and finalized evidence are immutable in the UI.
# - Missing providers show an explicit unavailable/degraded state; never invent results.
# - Module routes belong in routes.ts and are discovered through TenantRoute.

# Validation
# npm run typecheck
# npx eslint src/modules/bank_reconciliation --ext .ts,.tsx --max-warnings 0
# npm run test -- bank_reconciliation
