// ✅ APPROVED: Security scanning and validation scripts
// Reference: docs/architecture/operational-runbooks.md § 5 (CI/CD Security)
// CRITICAL NOTES:
// - All security scanning MUST pass before deployment (engineering-governance-and-pr-controls.md § 3)
// - SAST scans (Semgrep) must validate no hardcoded secrets (security-model.md § 5)
// - DAST scans (OWASP ZAP) must validate CORS and authentication enforcement
// - Dependency scanning must enforce audit-level thresholds (no unresolved vulnerabilities)
// - Container images must pass Trivy scanning (zero critical/high vulnerabilities)
// - TypeScript type checking MUST have ZERO errors (engineering-governance-and-pr-controls.md § 2.1)
// - ESLint MUST have ZERO warnings, especially for unsafe 'any' types
// - All security scanning results captured in audit logs (security-model.md § 4.2)
// Source: docs/architecture/engineering-governance-and-pr-controls.md § 3

{
  "scripts": {
    "lint:security": "eslint . --ext .ts,.tsx,.js,.jsx --config .eslintrc.security.js",
    "lint:security:basic": "eslint . --ext .ts,.tsx --config .eslintrc.security.dev.js",
    "lint:security:strict": "eslint . --ext .ts,.tsx --config .eslintrc.security.staging.js",
    "lint:security:maximum": "eslint . --ext .ts,.tsx --config .eslintrc.security.prod.js",
    "test:security:basic": "jest --testPathPattern=security --config jest.security.dev.js",
    "test:security:standard": "jest --testPathPattern=security --config jest.security.staging.js",
    "test:security:comprehensive": "jest --testPathPattern=security --config jest.security.prod.js",
    "sast:scan": "semgrep --config=auto .",
    "sast:scan:comprehensive": "semgrep --config=auto --config=p/security-audit .",
    "dast:scan": "zap-baseline.py -t http://localhost:20000",
    "dependency:scan": "npm audit --audit-level high",
    "dependency:scan:strict": "npm audit --audit-level moderate",
    "container:security:scan": "trivy image saraise:latest"
  }
}

